<?xml version="1.0"?>
<robot name="tfg_robot">

  <!-- base -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.45 0.35 0.2"/>
      </geometry>
      <material name="blue">
        <color rgba="0.1 0.1 0.8 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.45 0.35 0.2"/>
      </geometry>
    </collision>
  </link>

  <!-- left wheel -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.08" length="0.05"/>
      </geometry>
    </visual>
  </link>

  <!-- right wheel -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.08" length="0.05"/>
      </geometry>
    </visual>
  </link>

  <!-- joints -->
  <joint name="left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.22 -0.05"/>
  </joint>

  <joint name="right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.22 -0.05"/>
  </joint>

</robot>